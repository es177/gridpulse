# GridPulse — Required API Keys
# Copy this file to .env and fill in your keys

# EIA (US Energy Information Administration) — free at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# NewsAPI — free tier at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Anthropic Claude API — for news extraction pipeline
ANTHROPIC_API_KEY=your_anthropic_api_key_here
